{
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "TodoRead",
      "TodoWrite",
      "WebFetch",
      "NotebookRead",
      "NotebookEdit",
      "Task",
      "Exit_plan_mode",
      "Bash",
      "WebSearch",
      "mcp__plugin_context-mode_context-mode__*",
      "mcp__code-review-graph__*",
      "mcp__sequential-thinking__*",
      "mcp__memory__*",
      "Skill(superpowers*)",
      "Skill(superpowers:writing-plans)",
      "Skill(superpowers:subagent-driven-development)",
      "Agent"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo rm -rf :*)",
      "Bash(dd if=/dev/zero of=*)"
    ],
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable",
    "additionalDirectories": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "sequential-thinking",
    "memory"
  ],
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if (Test-Path ~/.env.ps1) { . ~/.env.ps1 }; if (Test-Path ~/.claude/notify_slack.ps1) { . ~/.claude/notify_slack.ps1 }",
            "shell": "powershell"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if (Test-Path ~/.env.ps1) { . ~/.env.ps1 }; $input | & ~/.claude/hooks/.venv/Scripts/python.exe ~/.claude/hooks/pre_tool_reviewer.py",
            "shell": "powershell"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if (Test-Path ~/.env.ps1) { . ~/.env.ps1 }; $input | & ~/.claude/hooks/.venv/Scripts/python.exe ~/.claude/hooks/stop_router.py; exit $LASTEXITCODE",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "AI reviewing...",
            "asyncRewake": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if (Test-Path ~/.env.ps1) { . ~/.env.ps1 }; $input | & ~/.claude/hooks/.venv/Scripts/python.exe ~/.claude/hooks/debug.py",
            "shell": "powershell"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if (Test-Path ~/.env.ps1) { . ~/.env.ps1 }; $input | & ~/.claude/hooks/.venv/Scripts/python.exe ~/.claude/hooks/debug.py",
            "shell": "powershell"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "forceLoginMethod": "claudeai",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "inputNeededNotifEnabled": true
}
